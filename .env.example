# ============================================
# 环境变量示例模板（可安全提交到版本控制）
# 复制此文件为对应的环境文件并填充真实值：
#   cp .env.example .env.development
#   cp .env.example .env.production
#   cp .env.example .env.production.local
#
# 安全规范：
# 1. 前端项目（Vue + Vite）所有以 VITE_ 开头的变量都会被打包到客户端代码中，
#    因此绝对不可放置数据库密码、后端密钥等敏感信息。
# 2. 数据库连接、后端密钥等敏感配置应仅存在于后端服务器的配置中。
# 3. 生产环境真实值应通过 CI/CD 环境变量或托管平台控制台注入，
#    而非硬编码在代码仓库内。
# ============================================

# ============================================
# 【前端】应用基础信息
# ============================================
# 应用名称，展示在页面标题及品牌区域
# 有效值：任意非空字符串
VITE_APP_NAME=AI心理健康助手

# 应用版本号，用于前端展示及调试
# 有效值：语义化版本号，如 0.0.1 / 1.2.0
VITE_APP_VERSION=0.0.0

# 当前运行环境标识
# 有效值：development（开发） / staging（预发布） / production（生产）
VITE_APP_ENV=development

# ============================================
# 【前端】API 接口配置
# ============================================
# 前端调用 API 的基础地址
# 开发环境：使用相对路径 /api，由 Vite 开发服务器代理转发
# 生产环境（方案A静态托管）：使用完整 HTTPS 域名，如 https://api.example.com/api
# 若前后端同域部署，可使用相对路径 /api，由托管平台边缘规则或 Nginx 反向代理
# 有效值：相对路径（以 / 开头）或完整 URL（以 http:// 或 https:// 开头）
VITE_API_BASE_URL=/api

# 接口请求超时时间（单位：毫秒）
# 有效值：正整数，建议范围 3000 ~ 30000
VITE_API_TIMEOUT=5000

# ============================================
# 【前端】静态资源与文件服务配置
# ============================================
# 后端文件服务基础地址，用于拼接封面图、头像等静态资源完整 URL
# 开发环境：直接指向后端服务器地址，如 http://159.75.169.224:1235
# 生产环境：应使用独立文件域名或 CDN 加速域名，如 https://files.example.com
# 有效值：完整 URL，末尾不带斜杠 /
VITE_FILE_BASE_URL=http://159.75.169.224:1235

# 知识库文章默认占位图地址（当文章无封面时展示）
# 生产环境建议托管到自有 CDN 或对象存储，避免依赖第三方图床
# 有效值：完整的图片 URL
VITE_KNOWLEDGE_PLACEHOLDER_URL=https://file.itndedu.com/psychology_ai.png

# ============================================
# 【前端】开发服务器代理配置（仅在开发环境生效）
# ============================================
# Vite 开发服务器代理目标地址，用于将前端 /api 请求转发到后端
# 仅本地开发时使用，生产构建会忽略此配置
# 有效值：完整的后端服务 URL，如 http://localhost:8080 或 http://192.168.1.10:1235
VITE_DEV_PROXY_TARGET=http://159.75.169.224:1235

# ============================================
# 【前端】功能开关与调试配置
# ============================================
# 是否启用 Vue DevTools 浏览器调试插件
# 开发环境建议开启，生产环境必须关闭以防止性能损耗和信息泄露
# 有效值：true / false
VITE_ENABLE_DEVTOOLS=true

# ============================================
# 【后端服务】配置参考（以下配置不应存在于前端项目中！）
# ============================================
# ⚠️ 警告：以下配置仅作为后端服务部署时的参考清单。
# 本前端项目不涉及后端服务代码，但为完整起见列出。
# 实际的后端数据库连接、密钥等应仅部署在服务器环境变量或安全密钥管理服务中。
#
# 数据库主机地址
# DB_HOST=localhost
#
# 数据库服务端口号
# 有效值：1 ~ 65535，常用 3306（MySQL）、5432（PostgreSQL）、27017（MongoDB）
# DB_PORT=3306
#
# 数据库名称
# DB_NAME=mental_health_db
#
# 数据库用户名
# DB_USER=root
#
# 数据库密码（敏感信息，必须使用强密码）
# DB_PASSWORD=<your-strong-password-here>
#
# 后端服务监听端口
# 有效值：1 ~ 65535，常用 8080 / 3000 / 5000 / 1235
# SERVER_PORT=1235
#
# JWT 签名密钥（敏感信息，建议使用 256 位随机字符串）
# JWT_SECRET=<your-jwt-secret-key-here>
#
# 第三方 AI 服务 API Key（敏感信息）
# AI_API_KEY=<your-ai-api-key-here>
#
# 对象存储 Access Key（敏感信息）
# OSS_ACCESS_KEY_ID=<your-oss-access-key-id>
# OSS_ACCESS_KEY_SECRET=<your-oss-access-key-secret>
